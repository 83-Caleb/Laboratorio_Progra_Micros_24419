                                 ; ***** BOOTLOADER DECLARATIONS ******************************************
                                 .equ	NRWW_START_ADDR	= 0x3800
                                 .equ	NRWW_STOP_ADDR	= 0x3fff
                                 .equ	RWW_START_ADDR	= 0x0
                                 .equ	RWW_STOP_ADDR	= 0x37ff
                                 .equ	PAGESIZE	= 64
                                 .equ	FIRSTBOOTSTART	= 0x3f00
                                 .equ	SECONDBOOTSTART	= 0x3e00
                                 .equ	THIRDBOOTSTART	= 0x3c00
                                 .equ	FOURTHBOOTSTART	= 0x3800
                                 .equ	SMALLBOOTSTART	= FIRSTBOOTSTART
                                 .equ	LARGEBOOTSTART	= FOURTHBOOTSTART
                                 
                                 
                                 
                                 ; ***** INTERRUPT VECTORS ************************************************
                                 .equ	INT0addr	= 0x0002	; External Interrupt Request 0
                                 .equ	INT1addr	= 0x0004	; External Interrupt Request 1
                                 .equ	PCI0addr	= 0x0006	; Pin Change Interrupt Request 0
                                 .equ	PCI1addr	= 0x0008	; Pin Change Interrupt Request 0
                                 .equ	PCI2addr	= 0x000a	; Pin Change Interrupt Request 1
                                 .equ	WDTaddr	= 0x000c	; Watchdog Time-out Interrupt
                                 .equ	OC2Aaddr	= 0x000e	; Timer/Counter2 Compare Match A
                                 .equ	OC2Baddr	= 0x0010	; Timer/Counter2 Compare Match A
                                 .equ	OVF2addr	= 0x0012	; Timer/Counter2 Overflow
                                 .equ	ICP1addr	= 0x0014	; Timer/Counter1 Capture Event
                                 .equ	OC1Aaddr	= 0x0016	; Timer/Counter1 Compare Match A
                                 .equ	OC1Baddr	= 0x0018	; Timer/Counter1 Compare Match B
                                 .equ	OVF1addr	= 0x001a	; Timer/Counter1 Overflow
                                 .equ	OC0Aaddr	= 0x001c	; TimerCounter0 Compare Match A
                                 .equ	OC0Baddr	= 0x001e	; TimerCounter0 Compare Match B
                                 .equ	OVF0addr	= 0x0020	; Timer/Couner0 Overflow
                                 .equ	SPIaddr	= 0x0022	; SPI Serial Transfer Complete
                                 .equ	URXCaddr	= 0x0024	; USART Rx Complete
                                 .equ	UDREaddr	= 0x0026	; USART, Data Register Empty
                                 .equ	UTXCaddr	= 0x0028	; USART Tx Complete
                                 .equ	ADCCaddr	= 0x002a	; ADC Conversion Complete
                                 .equ	ERDYaddr	= 0x002c	; EEPROM Ready
                                 .equ	ACIaddr	= 0x002e	; Analog Comparator
                                 .equ	TWIaddr	= 0x0030	; Two-wire Serial Interface
                                 .equ	SPMRaddr	= 0x0032	; Store Program Memory Read
                                 
                                 .equ	INT_VECTORS_SIZE	= 52	; size in words
                                 
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 // Ingeniería Mecatrónica
                                 // Programación de Microcontroladores
                                 // Proyecto Assembler: Reloj
                                 // Caleb Portillo - 24419
                                 
                                 .include "M328PDEF.inc" // Nombres de registros específicos del ATmega328P
                                 
                                 ;***** Created: 2011-02-09 12:03 ******* Source: ATmega328P.xml **********
                                 ;*************************************************************************
                                 ;* A P P L I C A T I O N   N O T E   F O R   T H E   A V R   F A M I L Y
                                 ;* 
                                 ;* Number            : AVR000
                                 ;* File Name         : "m328Pdef.inc"
                                 ;* Title             : Register/Bit Definitions for the ATmega328P
                                 ;* Date              : 2011-02-09
                                 ;* Version           : 2.35
                                 ;* Support E-mail    : avr@atmel.com
                                 ;* Target MCU        : ATmega328P
                                 ;* 
                                 ;* DESCRIPTION
                                 ;* When including this file in the assembly program file, all I/O register 
                                 ;* names and I/O register bit names appearing in the data book can be used.
                                 ;* In addition, the six registers forming the three data pointers X, Y and 
                                 ;* Z have been assigned names XL - ZH. Highest RAM address for Internal 
                                 ;* SRAM is also defined 
                                 ;* 
                                 ;* The Register names are represented by their hexadecimal address.
                                 ;* 
                                 ;* The Register Bit names are represented by their bit number (0-7).
                                 ;* 
                                 ;* Please observe the difference in using the bit names with instructions
                                 ;* such as "sbr"/"cbr" (set/clear bit in register) and "sbrs"/"sbrc"
                                 ;* (skip if bit in register set/cleared). The following example illustrates
                                 ;* this:
                                 ;* 
                                 ;* in    r16,PORTB             ;read PORTB latch
                                 ;* sbr   r16,(1<<PB6)+(1<<PB5) ;set PB6 and PB5 (use masks, not bit#)
                                 ;* out   PORTB,r16             ;output to PORTB
                                 ;* 
                                 ;* in    r16,TIFR              ;read the Timer Interrupt Flag Register
                                 ;* sbrc  r16,TOV0              ;test the overflow flag (use bit#)
                                 ;* rjmp  TOV0_is_set           ;jump if set
                                 ;* ...                         ;otherwise do something else
                                 ;*************************************************************************
                                 
                                 #ifndef _M328PDEF_INC_
                                 #endif  /* _M328PDEF_INC_ */
                                 
                                 ; ***** END OF FILE ******************************************************
                                 
                                 // *********************************************************************************************************************************************//
                                 // DATA SEGMENT: Registros que se almacenan en la SRAM
                                 .dseg 
000100                           botones: .byte 1 // Para guardar el estado de los botones
000101                           disp_activo: .byte 1 // Para saber qué display está encendido en este instante
000102                           disp_config: .byte 1 // Para saber qué display estamos configurando
                                 
                                 // Códigos HEX de cada display
000103                           disp_i1: .byte 1 // Display izquierda 1
000104                           disp_i2: .byte 1 // Display izquierda 2
000105                           disp_d1: .byte 1 // Display derecha 1
000106                           disp_d2: .byte 1 // Display derecha 2
                                 
                                 // Contadores generales para cada medida de tiempo (unidades + decenas)
000107                           cnt_LEDR: .byte 1
000108                           cnt_horas: .byte 1
000109                           cnt_dias: .byte 1
00010a                           cnt_meses: .byte 1
                                 
                                 // Contadores de unidades y decenas para cada medida de tiempo
00010b                           u_minutos: .byte 1
00010c                           d_minutos: .byte 1
00010d                           u_horas: .byte 1
00010e                           d_horas: .byte 1
00010f                           u_dias: .byte 1
000110                           d_dias: .byte 1
000111                           u_meses: .byte 1
000112                           d_meses: .byte 1
                                 
                                 // Contadores para alarma
000113                           al_u_minutos: .byte 1
000114                           al_d_minutos: .byte 1
000115                           al_u_horas: .byte 1
000116                           al_d_horas: .byte 1
000117                           al_horas: .byte 1
000118                           backup_u_minutos: .byte 1
000119                           backup_d_minutos: .byte 1
00011a                           backup_u_horas: .byte 1
00011b                           backup_d_horas: .byte 1
00011c                           backup_horas: .byte 1
00011d                           flag_alarma: .byte 1
                                 
00011e                           config: .byte 1 // Bandera de configuración [0xFF es config activada]
00011f                           modo: .byte 1 // Indicador de modo (fecha/hora) [0xFF es modo fecha, 0x00 es modo hora, 0x55 es config alarma]
                                 
                                 // *********************************************************************************************************************************************//
                                 // CODE SEGMENT: Comienza el programa
                                 .cseg
                                 .org 0x00 // O ".org SRAM_START"
000000 c020                        	RJMP start
                                 
                                 .org PCI0addr // Interrupción para pin change en PORTB
000006 c1cf                      	RJMP ISR_PCINT0
                                 
                                 .org OVF2addr // Interrupción por timer2
000012 c402                      	RJMP ISR_timer2
                                 
                                 .org OVF1addr // Interrupción por timer1
00001a c445                      	RJMP ISR_timer1
                                 
                                 .org OVF0addr // Interrupción por timer0
000020 c470                      	RJMP ISR_timer0
                                 	
                                 // *********************************************************************************************************************************************//
                                 // Configuraciones generales del microcontrolador
                                 
                                 	start:
000021 94f8                      	CLI
                                 
                                 	// Configuración de "la pila"
000022 ef0f                      		LDI R16, LOW(RAMEND) // LDI R16, 0xFF
000023 bf0d                      		OUT SPL, R16 // Stack pointer low
000024 e008                      		LDI R16, HIGH(RAMEND) // LDI R16 0x08
000025 bf0e                      		OUT SPH, R16 // Ahora este tiene 0x08FF
                                 
                                 		// Configuración del oscilador general a 1MHz
000026 e800                      		LDI R16, (1<<CLKPCE) // Carga 0x80 (1000_0000)
000027 9300 0061                 		STS CLKPR, R16 // Enable del prescaler
000029 e004                      		LDI R16, (1<<CLKPS2) // Set del CLKPS2 (0000_0100), que divide entre 16
                                 		//LDI R16, 0x00 // Borrar
00002a 9300 0061                 		STS CLKPR, R16
                                 
                                 	// DESHABILITAR ADC (Si no, no se puede usar PORTC como pines digitales (Se les conectaron LEDs y transistores)
00002c 9100 007a                 		LDS r16, ADCSRA
00002e 770f                      		CBR r16, (1 << ADEN)
00002f 9300 007a                 		STS ADCSRA, r16
                                 
                                 	// Deshabilitar UART (Para usar PD0 y PD1, que son Tx y Rx) (Se les conectaron pines del display)
000031 e000                      		LDI R16, 0x00
000032 9300 00c1                 		STS UCSR0B, R16
                                 
                                 	// Timer0 (Parpadeo de LEDs rojas)
000034 e005                      		LDI R16, (1<<CS02)|(1<<CS00) // Prescaler de 1024
000035 bd05                      		OUT TCCR0B, R16
000036 e00c                      		LDI R16, 12 // Empezamos a contar en 12
000037 bd06                      		OUT TCNT0, R16
000038 e001                      		LDI R16, (1<<TOIE0) // Enable de la interrupción Timer/Counter0
000039 9300 006e                 		STS TIMSK0, R16
                                 
                                 	// Timer1 (contador de minutos)
00003b e000                      		LDI R16, 0x00
00003c 9300 0080                 		STS TCCR1A, R16 // Timer1 en modo normal
00003e e005                      		LDI R16, (1<<CS12)|(1<<CS10)
                                 		//LDI R16, (1<<CS11) // Borrar
00003f 9300 0081                 		STS TCCR1B, R16 // Prescaler de 1024
000041 e10b                      		LDI R16, 0x1B
000042 9300 0085                 		STS TCNT1H, R16 // Valor inicial H para 60s
000044 e10e                      		LDI R16, 0x1E
000045 9300 0084                 		STS TCNT1L, R16 // Valor inicial L para 60s
000047 e001                      		LDI R16, (1<<TOIE1)
000048 9300 006f                 		STS TIMSK1, R16 // Enable de la interrupción por overflow
                                 
                                 	// Timer2 (para alternar displays de 7 segmentos)
00004a e000                      		LDI R16, 0x00
00004b 9300 00b0                 		STS TCCR2A, R16 // Timer2 en modo normal
00004d e006                      		LDI R16, (1<<CS22)|(1<<CS21) // Prescaler de 256
00004e 9300 00b1                 		STS TCCR2B, R16
000050 ef0e                      		LDI R16, 254 // Empezar a contar desde 254
000051 9300 00b2                 		STS TCNT2, R16
000053 e001                      		LDI R16, (1<<TOIE2) // Enable del overflow interrupt
000054 9300 0070                 		STS TIMSK2, R16
                                 
                                 	// Interrupciones por pin change
000056 e001                      		LDI R16, (1<<PCIE0) // Enable del PORTB
000057 9300 0068                 		STS PCICR, R16
000059 e10f                      		LDI R16, (1<<PCINT0)|(1<<PCINT1)|(1<<PCINT2)|(1<<PCINT3)|(1<<PCINT4)  // Selección de los bits PB4-0 para interrupciones
00005a 9300 006b                 		STS PCMSK0, R16
                                 
                                 	// Puertos I/O
00005c e200                      		LDI R16, 0x20 // PB4-0 tiene los botones, PB5 es para las LEDs rojas
00005d b904                      		OUT DDRB, R16
00005e e30f                      		LDI R16, 0x3F // PC0 es la LED azul, PC1 es la LED verde, PC5-2 tiene los ENABLE de los displays
00005f b907                      		OUT DDRC, R16
000060 ef0f                      		LDI R16, 0xFF // Display de 7 segmentos, todo OUTPUT
000061 b90a                      		OUT DDRD, R16
                                 
                                 	// Configuración de LEDs y botones
000062 e10f                      		LDI R16, 0x1F // Todos los botones con resistencia Pull-Up y LEDs R apagadas
000063 b905                      		OUT PORTB, R16
000064 e30c                      		LDI R16, 0x3C // LEDs A/V apagadas y todos los displays enabled
000065 b908                      		OUT PORTC, R16
000066 e000                      		LDI R16, 0x00 // Displays apagados
000067 b90b                      		OUT PORTD, R16
                                 
                                 	// Configuración del vector z
000068 e0f9                      		LDI ZH, HIGH(Table_7seg<<1)
000069 e6e4                      		LDI ZL, LOW(Table_7seg<<1)
                                 
                                 	// Inicializar registros a utilizar
                                 
                                 		// Registros en la SRAM
00006a e10f                      		LDI R16, 0x1F // Estado inicial de los botones (arriba en Pull-Up)
00006b 9300 0100                 		STS botones, R16
                                 
00006d 9104                      		LPM R16, Z // Estado inicial de los displays (todos en 0)
00006e 9300 0103                 		STS disp_i1, R16
000070 9300 0104                 		STS disp_i2, R16
000072 9300 0105                 		STS disp_d1, R16
000074 9300 0106                 		STS disp_d2, R16
                                 
000076 2700                      		CLR R16 // Los demás registros comienzan en 0
                                 		
000077 9300 011e                 		STS config, R16
000079 9300 011f                 		STS modo, R16
00007b 9300 0101                 		STS disp_activo, R16
00007d 9300 0102                 		STS disp_config, R16
                                 		
00007f 9300 0107                 		STS cnt_LEDR, R16
000081 9300 0108                 		STS cnt_horas, R16
                                 
000083 9300 010b                 		STS u_minutos, R16
000085 9300 010c                 		STS d_minutos, R16
000087 9300 010d                 		STS u_horas, R16
000089 9300 010e                 		STS d_horas, R16
00008b 9300 0110                 		STS d_dias, R16
00008d 9300 0112                 		STS d_meses, R16
                                 
00008f e001                      		LDI R16, 0x01 // El modo fecha empieza desde el 1 de enero
000090 9300 010f                 		STS u_dias, R16
000092 9300 0111                 		STS u_meses, R16
000094 9300 0109                 		STS cnt_dias, R16
000096 9300 010a                 		STS cnt_meses, R16
                                 
000098 e000                      		LDI R16, 0x00 // La alarma está programada por default para las 7 de la mañana
000099 9300 0113                 		STS al_u_minutos, R16
00009b 9300 0114                 		STS al_d_minutos, R16
00009d 9300 0116                 		STS al_d_horas, R16
00009f 9300 0118                 		STS backup_u_minutos, R16
0000a1 9300 0119                 		STS backup_d_minutos, R16
0000a3 9300 011a                 		STS backup_u_horas, R16
0000a5 9300 011b                 		STS backup_d_horas, R16
0000a7 9300 011c                 		STS backup_horas, R16
                                 
0000a9 e007                      		LDI R16, 0x07
0000aa 9300 0115                 		STS al_u_horas, R16
0000ac 9300 0117                 		STS al_horas, R16
0000ae e000                      		LDI R16, 0x00
0000af 9300 011d                 		STS flag_alarma, R16
                                 
                                 		// Registros de propósito general
0000b1 2700                      		CLR R16
0000b2 2711                      		CLR R17
0000b3 2722                      		CLR R18
0000b4 2733                      		CLR R19
0000b5 2744                      		CLR R20
0000b6 2755                      		CLR R21
0000b7 2766                      		CLR R22
0000b8 2777                      		CLR R23
0000b9 2788                      		CLR R24
0000ba 27cc                      		CLR R28
0000bb 27dd                      		CLR R29
0000bc 27ee                      		CLR R30
0000bd 2755                      		CLR R21
                                 
                                 		// Estado incial de los displays (solo durante la carga inicial)
0000be 9104                      		LPM R16, Z // Guardar el número actual (0 en el display)
0000bf b90b                      		OUT PORTD, R16 // Mostrar el número 0
                                 
0000c0 9478                      		SEI // Habilitar interrupciones globales
                                 
                                 // *********************************************************************************************************************************************//
                                 // Programa principal
                                 
                                 // Subrutinas para mostrar fecha y hora según el modo
                                 
                                 	Verificar_MODO:
0000c1 9100 011f                 		LDS R16, modo
0000c3 3f0f                      		CPI R16, 0xFF
0000c4 f409                      		BRNE HORA
0000c5 c02a                      		RJMP FECHA
                                 
                                 	HORA:
                                 		// Unidades de minutos
0000c6 e0f9                      		LDI ZH, HIGH(Table_7seg<<1)	// Regresamos el valor de Z a 0 en el display
0000c7 e6e4                      		LDI ZL, LOW(Table_7seg<<1)
0000c8 9100 010b                 		LDS R16, u_minutos
0000ca 0fe0                      		ADD ZL, R16
0000cb 9114                      		LPM R17, Z
0000cc 9310 0106                 		STS disp_d2, R17
                                 
                                 		// Decenas de minutos
0000ce e0f9                      		LDI ZH, HIGH(Table_7seg<<1)	// Regresamos el valor de Z a 0 en el display
0000cf e6e4                      		LDI ZL, LOW(Table_7seg<<1)
0000d0 9100 010c                 		LDS R16, d_minutos
0000d2 0fe0                      		ADD ZL, R16
0000d3 9114                      		LPM R17, Z
0000d4 9310 0105                 		STS disp_d1, R17
                                 
                                 		// Unidades de horas
0000d6 e0f9                      		LDI ZH, HIGH(Table_7seg<<1)	// Regresamos el valor de Z a 0 en el display
0000d7 e6e4                      		LDI ZL, LOW(Table_7seg<<1)
0000d8 9100 010d                 		LDS R16, u_horas
0000da 0fe0                      		ADD ZL, R16
0000db 9114                      		LPM R17, Z
0000dc 9310 0104                 		STS disp_i2, R17
                                 
                                 		// Decenas de horas
0000de e0f9                      		LDI ZH, HIGH(Table_7seg<<1)	// Regresamos el valor de Z a 0 en el display
0000df e6e4                      		LDI ZL, LOW(Table_7seg<<1)
0000e0 9100 010e                 		LDS R16, d_horas
0000e2 0fe0                      		ADD ZL, R16
0000e3 9114                      		LPM R17, Z
0000e4 9310 0103                 		STS disp_i1, R17
                                 
0000e6 9100 011f                 		LDS R16, modo
0000e8 3505                      		CPI R16, 0x55 // Si estamos configurando alarma, encendemos ambas luces
0000e9 f019                      		BREQ PC+4
0000ea 9a40                      		SBI PORTC, PORTC0 // LA encendida
0000eb 9841                      		CBI PORTC, PORTC1 // LV apagada
0000ec c026                      		RJMP Verificar_OVF
                                 
0000ed 9a40                      		SBI PORTC, PORTC0 // LA encendida
0000ee 9a41                      		SBI PORTC, PORTC1 // LV encendida
0000ef c023                      		RJMP Verificar_OVF
                                 
                                 
                                 	FECHA:
                                 		// Unidades de dias
0000f0 e0f9                      		LDI ZH, HIGH(Table_7seg<<1)	// Regresamos el valor de Z a 0 en el display
0000f1 e6e4                      		LDI ZL, LOW(Table_7seg<<1)
0000f2 9100 010f                 		LDS R16, u_dias
0000f4 0fe0                      		ADD ZL, R16
0000f5 9114                      		LPM R17, Z
0000f6 9310 0104                 		STS disp_i2, R17
                                 
                                 		// Decenas de dias
0000f8 e0f9                      		LDI ZH, HIGH(Table_7seg<<1)	// Regresamos el valor de Z a 0 en el display
0000f9 e6e4                      		LDI ZL, LOW(Table_7seg<<1)
0000fa 9100 0110                 		LDS R16, d_dias
0000fc 0fe0                      		ADD ZL, R16
0000fd 9114                      		LPM R17, Z
0000fe 9310 0103                 		STS disp_i1, R17
                                 
                                 		// Unidades de meses
000100 e0f9                      		LDI ZH, HIGH(Table_7seg<<1)	// Regresamos el valor de Z a 0 en el display
000101 e6e4                      		LDI ZL, LOW(Table_7seg<<1)
000102 9100 0111                 		LDS R16, u_meses
000104 0fe0                      		ADD ZL, R16
000105 9114                      		LPM R17, Z
000106 9310 0106                 		STS disp_d2, R17
                                 
                                 		// Decenas de meses
000108 e0f9                      		LDI ZH, HIGH(Table_7seg<<1)	// Regresamos el valor de Z a 0 en el display
000109 e6e4                      		LDI ZL, LOW(Table_7seg<<1)
00010a 9100 0112                 		LDS R16, d_meses
00010c 0fe0                      		ADD ZL, R16
00010d 9114                      		LPM R17, Z
00010e 9310 0105                 		STS disp_d1, R17
                                 		
000110 9a41                      		SBI PORTC, PORTC1
000111 9840                      		CBI PORTC, PORTC0
000112 c000                      		RJMP Verificar_OVF
                                 
                                 // Subrutinas de overflow para los contadores
                                 
                                 	Verificar_OVF:
000113 9110 010b                 		LDS R17, u_minutos // Leemos las unidades de minutos que han pasado
000115 301a                      		CPI R17, 0x0A // Si ya pasaron 10 u_minutos, hacemos overflow a decenas de minutos
000116 f5c0                      		BRSH INC_d_minutos
                                 
000117 9120 010c                 		LDS R18, d_minutos // Leemos las decenas de minutos que han pasado
000119 3026                      		CPI R18, 0x06 // Si ya pasaron 60 minutos, hacemos overflow a unidades de hora
00011a f008                      		BRLO PC+2
00011b c03e                      		RJMP INC_u_horas
                                 		
00011c 9130 010d                 		LDS R19, u_horas // Leemos las unidades de horas que han pasado
00011e 303a                      		CPI R19, 0x0A // Si ya pasaron 10 horas, hacemos overflow a decenas de hora
00011f f008                      		BRLO PC+2
000120 c04b                      		RJMP INC_d_horas
                                 		
000121 9110 0108                 		LDS R17, cnt_horas // Leemos las horas totales que han pasado (0 a 24)
000123 3118                      		CPI R17, 24 // Si ya pasaron 24 horas, incrementamos el dia
000124 f008                      		BRLO PC+2
000125 c04f                      		RJMP INC_u_dias_A
                                 		
000126 9150 010f                 		LDS R21, u_dias // Leemos las unidades de días que han pasado
000128 305a                      		CPI R21, 0x0A // Si ya pasaron 10, hacemos overflow a decenas de días
000129 f008                      		BRLO PC+2
00012a c069                      		RJMP INC_d_dias
                                 
00012b 9160 0110                 		LDS R22, d_dias
00012d 3064                      		CPI R22, 0x04 // Impedimos que se pueda cargar más de 4 decenas de días en el modo config
00012e f419                      		BRNE Verificar_OVF_cnt_dias
00012f 2766                      		CLR R22
000130 9360 0110                 		STS d_dias, R22
                                 		
                                 		Verificar_OVF_cnt_dias:
000132 9110 0109                 		LDS R17, cnt_dias // Cargamos el contador actual de dias
                                 
000134 9120 010a                 		LDS R18, cnt_meses // Tenemos que verificar si estamos en febrero, que es un caso especial
000136 3022                      		CPI R18, 2
000137 f419                      		BRNE PC+4 // Si no, saltamos al siguiente bloque
000138 311d                      		CPI R17, 29
000139 f008                      		BRLO PC+2 // Si estamos en un día mayor o igual a 29, nos vamos a incrementar meses
00013a c072                      		RJMP INC_u_meses
                                 
00013b 3210                      		CPI R17, 32 // Si ya pasaron 31 días, toca incrementar el mes
00013c f008                      		BRLO PC+2
00013d c06f                      		RJMP INC_u_meses
00013e 311f                      		CPI R17, 31 // Si ya pasaron 30 días, verificamos en qué mes estamos
00013f f008                      		BRLO PC+2
000140 c061                      		RJMP V_30_DIAS
000141 311d                      		CPI R17, 29 // Si ya pasaron 28 días, verificamos si estamos en febrero
000142 f008                      		BRLO PC+2
000143 c059                      		RJMP V_28_DIAS
                                 
000144 9170 0111                 		LDS R23, u_meses
000146 307a                      		CPI R23, 0x0A // Si se incrementa de 9 a 10 meses, debemos hacer overflow en unidades de meses
000147 f008                      		BRLO PC+2
000148 c07b                      		RJMP INC_d_meses
                                 		
000149 9120 010a                 		LDS R18, cnt_meses // Revisamos si ya pasaron 12 meses para reiniciar
00014b 302d                      		CPI R18, 13
00014c f008                      		BRLO PC+2
00014d c07f                      		RJMP Reinicio_reloj
                                 
00014e cf72                      		RJMP Verificar_MODO
                                 
                                 	INC_d_minutos:
00014f 2711                      		CLR R17
000150 9310 010b                 		STS u_minutos, R17 // Reiniciamos u_minutos, pasa de 9 a 0
                                 
000152 9120 010c                 		LDS R18, d_minutos // Leemos las decenas de minutos que han pasado
000154 9523                      		INC R18 // Aumentamos las decenas de minutos
000155 3026                      		CPI R18, 0x06 // Si ya pasaron 60 minutos, hacemos overflow a unidades de hora
000156 f418                      		BRSH INC_u_horas
                                 
000157 9320 010c                 		STS d_minutos, R18
000159 cf67                      		RJMP Verificar_MODO
                                 
                                 	INC_u_horas:
00015a 2722                      		CLR R18
00015b 9320 010c                 		STS d_minutos, R18 // Reiniciamos d_minutos, pasa de 5 a 0 (59 a 00 en los display d)
                                 
00015d 9110 0108                 		LDS R17, cnt_horas // Leemos las horas totales que han pasado (0 a 24)
00015f 9513                      		INC R17 // Aumentamos 1
000160 3118                      		CPI R17, 24 // Si ya pasaron 24 horas, incrementamos el dia
000161 f498                      		BRSH INC_u_dias_A
                                 
000162 9310 0108                 		STS cnt_horas, R17 // Guardamos el nuevo valor de horas generales
                                 
000164 9130 010d                 		LDS R19, u_horas // Leemos las unidades de horas que han pasado
000166 9533                      		INC R19 // Incrementamos
000167 303a                      		CPI R19, 0x0A // Si ya pasaron 10 horas, hacemos overflow a decenas de hora
000168 f418                      		BRSH INC_d_horas
                                 
000169 9330 010d                 		STS u_horas, R19
00016b cf55                      		RJMP Verificar_MODO
                                 
                                 	INC_d_horas: // Si entramos a esta subrutina, es porque no está ocurriendo incremento de día
00016c 2733                      		CLR R19
00016d 9330 010d                 		STS u_horas, R19 // Reiniciamos unidades de horas
                                 
00016f 9140 010e                 		LDS R20, d_horas // Leemos las decenas de horas que han pasado
000171 9543                      		INC R20
000172 9340 010e                 		STS d_horas, R20 // Guardamos el nuevo valor
000174 cf4c                      		RJMP Verificar_MODO
                                 
                                 	INC_u_dias_A:
000175 2700                      		CLR R16 // Reiniciamos los contadores de horas
000176 9300 0108                 		STS cnt_horas, R16
000178 9300 010d                 		STS u_horas, R16
00017a 9300 010e                 		STS d_horas, R16		
                                 
00017c 9110 0109                 		LDS R17, cnt_dias // Cargamos el día actual e incrementamos 1
00017e 9513                      		INC R17
                                 
00017f 3210                      		CPI R17, 32 // Si ya pasaron 31 días, toca incrementar el mes
000180 f560                      		BRSH INC_u_meses
                                 		
000181 311f                      		CPI R17, 31 // Si ya pasaron 30 días, verificamos en qué mes estamos
000182 f4f8                      		BRSH V_30_DIAS
                                 		
000183 311d                      		CPI R17, 29 // Si ya pasaron 28 días, verificamos si estamos en febrero
000184 f4c0                      		BRSH V_28_DIAS
                                 
                                 	INC_u_dias_B:
000185 9310 0109                 		STS cnt_dias, R17 // Si no se activa ninguna de esas subrutinas, guardamos el valor nuevo de cnt_dias
                                 
000187 9100 011e                 		LDS R16, config
000189 3f0f                      		CPI R16, 0xFF
00018a f409                      		BRNE PC+2
00018b cf35                      		RJMP Verificar_modo
                                 
00018c 9150 010f                 		LDS R21, u_dias
00018e 9553                      		INC R21
00018f 305a                      		CPI R21, 0x0A
000190 f418                      		BRSH INC_d_dias
                                 
000191 9350 010f                 		STS u_dias, R21
000193 cf2d                      		RJMP Verificar_MODO
                                 
                                 	INC_d_dias:
000194 2755                      		CLR R21
000195 9350 010f                 		STS u_dias, R21
                                 
000197 9160 0110                 		LDS R22, d_dias
000199 9563                      		INC R22
00019a 9360 0110                 		STS d_dias, R22
00019c cf24                      		RJMP Verificar_MODO
                                 
                                 	V_28_DIAS: // Si estamos en febrero, el mes cambia después de 28 días
00019d 9100 010a                 		LDS R16, cnt_meses
00019f 3002                      		CPI R16, 2
0001a0 f721                      		BRNE INC_u_dias_B // Si no estamos en febrero, regresamos al flujo de incremento normal
0001a1 c00b                      		RJMP INC_u_meses
                                 
                                 	V_30_DIAS:
0001a2 9100 010a                 		LDS R16, cnt_meses
                                 
0001a4 3004                      		CPI R16, 4 // Estamos en abril?
0001a5 f039                      		BREQ INC_u_meses
                                 
0001a6 3006                      		CPI R16, 6 // Estamos en junio?
0001a7 f029                      		BREQ INC_u_meses
                                 
0001a8 3009                      		CPI R16, 9 // Estamos en septiembre?
0001a9 f019                      		BREQ INC_u_meses
                                 
0001aa 300b                      		CPI R16, 11 // Estamos en noviembre?
0001ab f009                      		BREQ INC_u_meses
                                 
0001ac cfd8                      		RJMP INC_u_dias_B
                                 
                                 	INC_u_meses:
0001ad e011                      		LDI R17, 0x01 // Los contadores de días vuelven a empezar desde 01
0001ae 9310 0109                 		STS cnt_dias, R17
0001b0 9310 010f                 		STS u_dias, R17
0001b2 2711                      		CLR R17
0001b3 9310 0110                 		STS d_dias, R17
                                 
0001b5 9120 010a                 		LDS R18, cnt_meses
0001b7 9523                      		INC R18
0001b8 302d                      		CPI R18, 13
0001b9 f498                      		BRSH Reinicio_reloj
0001ba 9320 010a                 		STS cnt_meses, R18
                                 
0001bc 9170 0111                 		LDS R23, u_meses
0001be 9573                      		INC R23
0001bf 307a                      		CPI R23, 0x0A
0001c0 f418                      		BRSH INC_d_meses
                                 
0001c1 9370 0111                 		STS u_meses, R23
0001c3 cefd                      		RJMP Verificar_MODO
                                 
                                 	INC_d_meses:
0001c4 2777                      		CLR R23
0001c5 9370 0111                 		STS u_meses, R23
                                 
0001c7 9180 0112                 		LDS R24, d_meses
0001c9 9583                      		INC R24
0001ca 9380 0112                 		STS d_meses, R24
0001cc cef4                      		RJMP Verificar_MODO
                                 
                                 	Reinicio_reloj:
0001cd e041                      		LDI R20, 0x01
0001ce 9340 010a                 		STS cnt_meses, R20
0001d0 9340 0111                 		STS u_meses, R20
0001d2 2744                      		CLR R20
0001d3 9340 0112                 		STS d_meses, R20
0001d5 ceeb                      		RJMP Verificar_MODO
                                 
                                 // *********************************************************************************************************************************************//
                                 // Subrutinas de programa
                                 
                                 // *********************************************************************************************************************************************//
                                 // Subrutinas de interrupción
                                 
                                 	// Interrupción para pin change en PORTB
                                 	ISR_PCINT0: 
0001d6 930f                      		PUSH R16
0001d7 b70f                      		IN   R16, SREG
0001d8 930f                      		PUSH R16
0001d9 931f                      		PUSH R17
0001da 932f                      		PUSH R18
0001db 933f                      		PUSH R19
0001dc 934f                      		PUSH R20
0001dd 935f                      		PUSH R21
0001de 936f                      		PUSH R22
                                 
0001df b113                      		IN R17, PINB // Lectura del estado actual de los botones
0001e0 731f                      		ANDI R17, 0x3F // Máscara para solo dejar PB5-0 con valor (no editamos el LED rojo)
                                 
                                 		// Verificamos los botones 4-1 (Si actualmente son 1 [no presionado], se ignora la subrutina correspondiente)
0001e1 9b19                      		SBIS PINB, 1
0001e2 c01e                      		RJMP BOTON_1
0001e3 9b1a                      		SBIS PINB, 2
0001e4 c08c                      		RJMP BOTON_2
0001e5 9b1b                      		SBIS PINB, 3
0001e6 c1c2                      		RJMP BOTON_3
0001e7 9b1c                      		SBIS PINB, 4
0001e8 c20c                      		RJMP BOTON_4
                                 
                                 		// Verificamos el botón 0 (config)
0001e9 2f21                      		MOV R18, R17 // Copia del estado actual de los botones
0001ea 7021                      		ANDI R18, 0x01 // Aislamos bit 0
0001eb 3020                      		CPI R18, 0x00 // Si es igual a 0, el botón se está presionando y CONFIG debe ser 0xFF
0001ec f081                      		BREQ BOTON_0
                                 
0001ed 9100 0100                 		LDS R16, botones // Cargamos el estado anterior de los botones
0001ef 7001                      		ANDI R16, 0x01 // Aislamos bit 0
0001f0 3000                      		CPI R16, 0x00
0001f1 f009                      		BREQ APAGAR_CONFIG // Si no esta presionado, se apaga la config
0001f2 c216                      		RJMP EXIT_ISR_PCINT0
                                 
                                 		APAGAR_CONFIG:
0001f3 2733                      			CLR R19
0001f4 9330 011e                 			STS config, R19 // Si no son iguales (BOTON_0 = 0), el botón estaba presionado y hubo flanco de subida, se resetea la bandera de config	
0001f6 9120 011f                 			LDS R18, modo
0001f8 3525                      			CPI R18, 0x55
0001f9 f411                      			BRNE MANTENER_MODO
0001fa 9330 011f                 			STS modo, R19 // Si no son iguales, se regresa el modo a hora para evitar entrar en alarma
                                 			MANTENER_MODO:
0001fc c20c                      			RJMP EXIT_ISR_PCINT0
                                 
                                 	BOTON_0:
0001fd ef0f                      		LDI R16, 0xFF
0001fe 9300 011e                 		STS config, R16 // Activamos configuración: config = 0xFF
000200 c208                      		RJMP EXIT_ISR_PCINT0
                                 
                                 	BOTON_1: // Botón de incremento
000201 9100 011e                 		LDS R16, config
000203 3000                      		CPI R16, 0x00
000204 f409                      		BRNE ACCION_B1
000205 c203                      		RJMP EXIT_ISR_PCINT0 // Si no estamos en configuración, no tiene efecto la pulsación
                                 
                                 		ACCION_B1:
000206 9100 011f                 		LDS R16, modo
000208 3f0f                      		CPI R16, 0xFF
000209 f171                      		BREQ B1_FECHA // Branch si estamos en modo fecha
                                 
00020a c000                      		RJMP B1_HORA // Branch si estamos en modo hora
                                 
                                 		B1_HORA:
00020b 9110 0102                 			LDS R17, disp_config // Incrementamos el valor del display seleccionado (cambia con el B4)
                                 			
00020d 3010                      			CPI R17, 0x00
00020e f031                      			BREQ INC_CONFIG_U_MINUTOS // disp_config = 0 incrementa u_minutos
00020f 3011                      			CPI R17, 0x01
000210 f051                      			BREQ INC_CONFIG_D_MINUTOS // disp_config = 1 incrementa d_minutos
000211 3012                      			CPI R17, 0x02
000212 f071                      			BREQ INC_CONFIG_U_HORAS // disp_config = 2 incrementa u_horas
000213 3013                      			CPI R17, 0x03
000214 f4b8                      			BRSH INC_CONFIG_D_HORAS // disp_config = 3 incrementa d_horas
                                 
                                 			INC_CONFIG_U_MINUTOS: // Aumentamos 1 minuto
000215 9130 010b                 				LDS R19, u_minutos
000217 9533                      				INC R19
000218 9330 010b                 				STS u_minutos, R19
00021a c1ee                      				RJMP EXIT_ISR_PCINT0
                                 
                                 			INC_CONFIG_D_MINUTOS: // Aumentamos 10 minutos
00021b 9130 010c                 				LDS R19, d_minutos
00021d 9533                      				INC R19
00021e 9330 010c                 				STS d_minutos, R19
000220 c1e8                      				RJMP EXIT_ISR_PCINT0
                                 
                                 			INC_CONFIG_U_HORAS: // Aumentamos 1 hora (en contador general y en el de unidades)
000221 9130 010d                 				LDS R19, u_horas 
000223 9533                      				INC R19
000224 9330 010d                 				STS u_horas, R19
                                 
000226 9140 0108                 				LDS R20, cnt_horas 
000228 9543                      				INC R20
000229 9340 0108                 				STS cnt_horas, R20
00022b c1dd                      				RJMP EXIT_ISR_PCINT0
                                 
                                 			INC_CONFIG_D_HORAS: // Aumentamos 10 horas en contador general y 1 en el de decenas
00022c 9130 010e                 				LDS R19, d_horas 
00022e 9533                      				INC R19
00022f 9330 010e                 				STS d_horas, R19
                                 
000231 9140 0108                 				LDS R20, cnt_horas
000233 e05a                      				LDI R21, 0x0A 
000234 0f45                      				ADD R20, R21
000235 9340 0108                 				STS cnt_horas, R20
000237 c1d1                      				RJMP EXIT_ISR_PCINT0
                                 
                                 		B1_FECHA:
000238 9110 0102                 			LDS R17, disp_config // Incrementamos el valor del display seleccionado (cambia con el B4)
                                 			
00023a 3010                      			CPI R17, 0x00
00023b f031                      			BREQ INC_CONFIG_U_DIAS // disp_config = 0 incrementa u_dias
00023c 3011                      			CPI R17, 0x01
00023d f079                      			BREQ INC_CONFIG_D_DIAS // disp_config = 1 incrementa d_dias
00023e 3012                      			CPI R17, 0x02
00023f f0c9                      			BREQ INC_CONFIG_U_MESES // disp_config = 2 incrementa u_meses
000240 3013                      			CPI R17, 0x03
000241 f510                      			BRSH INC_CONFIG_D_MESES // disp_config = 3 incrementa d_meses
                                 
                                 			INC_CONFIG_U_DIAS: // Aumentamos 1 dia (en contador general y en el de unidades)
000242 9130 010f                 				LDS R19, u_dias
000244 9533                      				INC R19
000245 9330 010f                 				STS u_dias, R19
                                 				
000247 9140 0109                 				LDS R20, cnt_dias 
000249 9543                      				INC R20
00024a 9340 0109                 				STS cnt_dias, R20
00024c c1bc                      				RJMP EXIT_ISR_PCINT0
                                 
                                 			INC_CONFIG_D_DIAS: // Aumentamos 10 dias en el contador general y 1 en el de decenas
00024d 9130 0110                 				LDS R19, d_dias
00024f 9533                      				INC R19
000250 9330 0110                 				STS d_dias, R19
                                 				
000252 9140 0109                 				LDS R20, cnt_dias
000254 e05a                      				LDI R21, 0x0A 
000255 0f45                      				ADD R20, R21
000256 9340 0109                 				STS cnt_dias, R20
000258 c1b0                      				RJMP EXIT_ISR_PCINT0
                                 
                                 			INC_CONFIG_U_MESES: // Aumentamos 1 mes (en contador general y en el de unidades)
000259 9130 0111                 				LDS R19, u_meses 
00025b 9533                      				INC R19
00025c 9330 0111                 				STS u_meses, R19
                                 
00025e 9140 010a                 				LDS R20, cnt_meses
000260 9543                      				INC R20
000261 9340 010a                 				STS cnt_meses, R20
000263 c1a5                      				RJMP EXIT_ISR_PCINT0
                                 
                                 			INC_CONFIG_D_MESES: // Aumentamos 10 meses en el contador general y 1 en el de decenas
000264 9130 0112                 				LDS R19, d_meses
000266 9533                      				INC R19
000267 9330 0112                 				STS d_meses, R19
                                 
000269 9140 010a                 				LDS R20, cnt_meses
00026b e05a                      				LDI R21, 0x0A 
00026c 0f45                      				ADD R20, R21
00026d 9340 010a                 				STS cnt_meses, R20
00026f c199                      				RJMP EXIT_ISR_PCINT0
                                 
000270 c198                      		RJMP EXIT_ISR_PCINT0
                                 		
                                 	BOTON_2: // Botón de decremento
000271 9100 011e                 		LDS R16, config
000273 3000                      		CPI R16, 0x00
000274 f409                      		BRNE ACCION_B2
000275 c193                      		RJMP EXIT_ISR_PCINT0 // Si no estamos en configuración, no tiene efecto la pulsación
                                 
                                 		ACCION_B2:
000276 9100 011f                 		LDS R16, modo
000278 3505                      		CPI R16, 0x55
000279 f019                      		BREQ B2_ALARMA // Branch si estamos en modo alarma
                                 
00027a 3000                      		CPI R16, 0x00
00027b f0b1                      		BREQ B2_HORA // Branch si estamos en modo hora
                                 
00027c c07e                      		RJMP B2_FECHA // Branch si estamos en modo fecha (no estamos en hora ni en alarma)
                                 
                                 		B2_ALARMA: // Guarda el valor nuevo de la alarma
00027d 9110 010b                 			LDS R17, u_minutos // Guardamos el valor editado
00027f 9310 0113                 			STS al_u_minutos, R17
000281 9110 010c                 			LDS R17, d_minutos // Guardamos el valor editado
000283 9310 0114                 			STS al_d_minutos, R17
000285 9110 010d                 			LDS R17, u_horas // Guardamos el valor editado
000287 9310 0115                 			STS al_u_horas, R17
000289 9110 010e                 			LDS R17, d_horas // Guardamos el valor editado
00028b 9310 0116                 			STS al_d_horas, R17
00028d 9110 0108                 			LDS R17, cnt_horas // Guardamos el valor editado
00028f 9310 0117                 			STS al_horas, R17
000291 c177                      			RJMP EXIT_ISR_PCINT0
                                 
                                 		B2_HORA:
000292 9110 0102                 			LDS R17, disp_config // Decrementamos el valor del display seleccionado (cambia con el B4)
                                 			
000294 3010                      			CPI R17, 0x00
000295 f029                      			BREQ DEC_CONFIG_U_MINUTOS // disp_config = 0 decrementa u_minutos
000296 3011                      			CPI R17, 0x01
000297 f079                      			BREQ DEC_CONFIG_D_MINUTOS // disp_config = 1 decrementa d_minutos
000298 3012                      			CPI R17, 0x02
000299 f0c9                      			BREQ DEC_CONFIG_U_HORAS // disp_config = 2 decrementa u_horas
                                 
00029a c047                      			RJMP DEC_CONFIG_D_HORAS // disp_config = 3 o más, decrementa d_horas
                                 
                                 			DEC_CONFIG_U_MINUTOS: // Regresamos 1 minuto
00029b 9130 010b                 				LDS R19, u_minutos
00029d 3030                      				CPI R19, 0x00
00029e f421                      				BRNE PC+5 // salta LDI(1) + STS(2) + RJMP(1) = 4
00029f e039                      				LDI R19, 0x09 // tarda 1 ciclo
0002a0 9330 010b                 				STS u_minutos, R19 // tarda 2 ciclos (hay que tomarlo en cuenta)
0002a2 c166                      				RJMP EXIT_ISR_PCINT0 // tarda 1 ciclo
                                 				
0002a3 953a                      				DEC R19
0002a4 9330 010b                 				STS u_minutos, R19
0002a6 c162                      				RJMP EXIT_ISR_PCINT0
                                 
                                 			DEC_CONFIG_D_MINUTOS: // Regresamos 10 minutos
0002a7 9130 010c                 				LDS R19, d_minutos
0002a9 3030                      				CPI R19, 0x00
0002aa f421                      				BRNE PC+5
0002ab e035                      				LDI R19, 0x05
0002ac 9330 010c                 				STS d_minutos, R19
0002ae c15a                      				RJMP EXIT_ISR_PCINT0
                                 				
0002af 953a                      				DEC R19
0002b0 9330 010c                 				STS d_minutos, R19
0002b2 c156                      				RJMP EXIT_ISR_PCINT0
                                 
                                 			DEC_CONFIG_U_HORAS: // Regresamos 1 hora (en contador general y en el de unidades)
0002b3 9140 0108                 				LDS R20, cnt_horas
0002b5 3040                      				CPI R20, 0x00 // Si estamos en 00 horas, regresar a 23
0002b6 f109                      				BREQ UNDERFLOW_HORAS
                                 				
0002b7 9130 010e                 				LDS R19, d_horas
0002b9 3030                      				CPI R19, 0x00 // Si las decenas de hora no son 0, verificamos si hay underflow
0002ba f021                      				BREQ PC+5 // Porque LDS tarda 2 ciclos
0002bb 9120 010d                 				LDS R18, u_horas
0002bd 3020                      				CPI R18, 0x00 // Si hay underflow, saltamos a UNDERFLOW_U_HORAS
0002be f059                      				BREQ UNDERFLOW_U_HORAS
                                 				
0002bf 9120 010d                 				LDS R18, u_horas // Si no hay underflow de ningún tipo, solo decrementamos las unidades y el contador
0002c1 952a                      				DEC R18
0002c2 9320 010d                 				STS u_horas, R18
0002c4 9140 0108                 				LDS R20, cnt_horas
0002c6 954a                      				DEC R20
0002c7 9340 0108                 				STS cnt_horas, R20
0002c9 c13f                      				RJMP EXIT_ISR_PCINT0
                                 				
                                 				UNDERFLOW_U_HORAS: // Pasamos de 10 a 09 o de 20 a 19 horas
0002ca 9140 0108                 					LDS R20, cnt_horas 
0002cc 954a                      					DEC R20 // Disminuye el contador general en 1
0002cd 9340 0108                 					STS cnt_horas, R20
0002cf 9130 010e                 					LDS R19, d_horas
0002d1 953a                      					DEC R19 // Disminuye las decenas en 1
0002d2 9330 010e                 					STS d_horas, R19
0002d4 e029                      					LDI R18, 0x09 // Regresamos las unidades a 9 
0002d5 9320 010d                 					STS u_horas, R18
0002d7 c131                      					RJMP EXIT_ISR_PCINT0
                                 					
                                 				UNDERFLOW_HORAS: // Pasamos de 00 a 23 horas
0002d8 e147                      					LDI R20, 23
0002d9 9340 0108                 					STS cnt_horas, R20 // Regresamos el contador a 23 horas
0002db e032                      					LDI R19, 0x02
0002dc 9330 010e                 					STS d_horas, R19 // Regresamos las decenas a 2
0002de e033                      					LDI R19, 0X03
0002df 9330 010d                 					STS u_horas, R19 // Regresamos las unidades a 3
0002e1 c127                      					RJMP EXIT_ISR_PCINT0
                                 
                                 			DEC_CONFIG_D_HORAS: // Regresamos 10 horas en contador general y 1 en el de decenas
0002e2 9140 0108                 				LDS R20, cnt_horas
0002e4 304a                      				CPI R20, 0x0A // Si en el contador general hay menos de 10 horas, hacemos underflow
0002e5 f058                      				BRLO UNDERFLOW_D_HORAS
                                 				
0002e6 9130 010e                 				LDS R19, d_horas 
0002e8 953a                      				DEC R19
0002e9 9330 010e                 				STS d_horas, R19
                                 
0002eb 9140 0108                 				LDS R20, cnt_horas
0002ed 504a                      				SUBI R20, 0x0A
0002ee 9340 0108                 				STS cnt_horas, R20
0002f0 c118                      				RJMP EXIT_ISR_PCINT0
                                 				
                                 				UNDERFLOW_D_HORAS: // Pasamos a 23 horas
0002f1 e147                      					LDI R20, 23
0002f2 9340 0108                 					STS cnt_horas, R20 // Regresamos el contador a 23 horas
0002f4 e032                      					LDI R19, 0x02
0002f5 9330 010e                 					STS d_horas, R19 // Regresamos las decenas a 2
0002f7 e033                      					LDI R19, 0X03
0002f8 9330 010d                 					STS u_horas, R19 // Regresamos las unidades a 3
0002fa c10e                      					RJMP EXIT_ISR_PCINT0
                                 
                                 		B2_FECHA:
0002fb 9110 0102                 			LDS R17, disp_config // Incrementamos el valor del display seleccionado (cambia con el B4)
                                 			
0002fd 3010                      			CPI R17, 0x00
0002fe f039                      			BREQ DEC_CONFIG_U_DIAS // disp_config = 0 decrementa u_dias
                                 			
0002ff 3011                      			CPI R17, 0x01
000300 f409                      			BRNE PC+2
000301 c055                      			RJMP DEC_CONFIG_D_DIAS // disp_config = 1 decrementa d_dias
                                 			
000302 3012                      			CPI R17, 0x02
000303 f409                      			BRNE PC+2
000304 c067                      			RJMP DEC_CONFIG_U_MESES // disp_config = 2 decrementa u_meses
                                 
000305 c08e                      			RJMP DEC_CONFIG_D_MESES // disp_config = 3+ decrementa d_meses
                                 
                                 			DEC_CONFIG_U_DIAS: // Regresamos 1 dia (en contador general y en el de unidades)
000306 9140 0109                 				LDS R20, cnt_dias // Verificamos si hay que hacer underflow, regresando a la cantidad máxima de días de cada mes
000308 3041                      				CPI R20, 0x01
000309 f109                      				BREQ UNDERFLOW_28_DIAS
                                 				
00030a 9120 0110                 				LDS R18, d_dias
00030c 3020                      				CPI R18, 0x00 // Decenas en 0?
00030d f021                      				BREQ PC+5 // Si las decenas están en 1, 2 o 3, verificamos si los días están en 0
00030e 9130 010f                 				LDS R19, u_dias
000310 3030                      				CPI R19, 0x00
000311 f059                      				BREQ UNDERFLOW_U_DIAS // Saltamos a hacer el underflow
                                 
000312 9140 0109                 				LDS R20, cnt_dias // Si no hay que hacer underflow, solo disminuimos una unidad de día de ambos contadores
000314 954a                      				DEC R20
000315 9340 0109                 				STS cnt_dias, R20
000317 9130 010f                 				LDS R19, u_dias
000319 953a                      				DEC R19
00031a 9330 010f                 				STS u_dias, R19
00031c c0ec                      				RJMP EXIT_ISR_PCINT0
                                 
                                 				UNDERFLOW_U_DIAS: // Pasamos de 10 a 09, 20 a 19 o 30 a 29
00031d 9140 0109                 					LDS R20, cnt_dias
00031f 954a                      					DEC R20
000320 9340 0109                 					STS cnt_dias, R20 // Restamos 1 día al contador
000322 9120 0110                 					LDS R18, d_dias
000324 952a                      					DEC R18
000325 9320 0110                 					STS d_dias, R18 // Restamos 1 a decenas de día
000327 e039                      					LDI R19, 0x09
000328 9330 010f                 					STS u_dias, R19 // Decenas de días a 9
00032a c0de                      					RJMP EXIT_ISR_PCINT0
                                 
                                 				UNDERFLOW_28_DIAS:
00032b 9100 010a                 					LDS R16, cnt_meses
00032d 3002                      					CPI R16, 0x02
00032e f451                      					BRNE UNDERFLOW_31_DIAS // Si no estamos en febrero, verificamos en qué mes estamos
                                 				
00032f e12c                      					LDI R18, 28 // Si estamos en febrero regresamos a 28 días
000330 9320 0109                 					STS cnt_dias, R18
000332 e038                      					LDI R19, 0x08 // Cargamos una unidad de día
000333 9330 010f                 					STS u_dias, R19
000335 e042                      					LDI R20, 0x02 // Cargamos 2 decenas de día
000336 9340 0110                 					STS d_dias, R20
000338 c0d0                      					RJMP EXIT_ISR_PCINT0
                                 
                                 				UNDERFLOW_31_DIAS:
000339 9100 010a                 					LDS R16, cnt_meses // Buscamos si estamos en un mes con 30 días
00033b 3004                      					CPI R16, 0x04 // Abril
00033c f081                      					BREQ UNDERFLOW_30_DIAS 
00033d 3006                      					CPI R16, 0x06 // Junio
00033e f071                      					BREQ UNDERFLOW_30_DIAS 
00033f 3009                      					CPI R16, 0x09 // Septiembre
000340 f061                      					BREQ UNDERFLOW_30_DIAS 
000341 300b                      					CPI R16, 0x0B // Noviembre
000342 f051                      					BREQ UNDERFLOW_30_DIAS 
                                 
000343 e12f                      					LDI R18, 31 // Si seguimos en esta subrutina, el mes en el que estamos tiene 31 días
000344 9320 0109                 					STS cnt_dias, R18
000346 e031                      					LDI R19, 0x01 // Cargamos una unidad de día
000347 9330 010f                 					STS u_dias, R19
000349 e043                      					LDI R20, 0x03 // Cargamos 1 decena de día
00034a 9340 0110                 					STS d_dias, R20
00034c c0bc                      					RJMP EXIT_ISR_PCINT0
                                 
                                 				UNDERFLOW_30_DIAS:
00034d e12e                      					LDI R18, 30 // Si caemos en esta subrutina, el mes en el que estamos tiene 30 días
00034e 9320 0109                 					STS cnt_dias, R18
000350 e030                      					LDI R19, 0x00 // Cargamos 0 como unidad de día
000351 9330 010f                 					STS u_dias, R19
000353 e043                      					LDI R20, 0x03 // Cargamos 3 decenas de día
000354 9340 0110                 					STS d_dias, R20
000356 c0b2                      					RJMP EXIT_ISR_PCINT0
                                 			
                                 			DEC_CONFIG_D_DIAS: // Restamos 10 días a los contadores
000357 9120 0110                 					LDS R18, d_dias
000359 e05a                      					LDI R21, 0x0A
00035a 9f25                      					MUL R18, R21    
00035b 9130 010f                 					LDS R19, u_dias
00035d 0e03                      					ADD R0, R19 // cnt_dias = d_dias*10 + u_dias
00035e 2d20                      					MOV R18, R0
00035f 9320 0109                 					STS cnt_dias, R18
                                 
000361 302b                      					CPI R18, 0x0B
000362 f240                      					BRLO UNDERFLOW_28_DIAS // Si el contador de días es igual o menor a 10 y restamos 10, cargamos los días máximos del mes correspondiente
000363 502a                      					SUBI R18, 0x0A
000364 9320 0109                 					STS cnt_dias, R18
000366 9130 0110                 					LDS R19, d_dias
000368 953a                      					DEC R19
000369 9330 0110                 					STS d_dias, R19
00036b c09d                      					RJMP EXIT_ISR_PCINT0
                                 
                                 			DEC_CONFIG_U_MESES:
00036c 9120 0112                 				LDS R18, d_meses //cnt_meses = d_meses*10 + u_meses
00036e e05a                      				LDI R21, 0x0A
00036f 9f25                      				MUL R18, R21      
000370 9130 0111                 				LDS R19, u_meses
000372 0e03                      				ADD R0, R19
000373 2d20                      				MOV R18, R0
000374 9320 010a                 				STS cnt_meses, R18  
                                 
000376 3021                      				CPI R18, 0x01
000377 f091                      				BREQ UNDERFLOW_MESES
000378 952a                      				DEC R18
000379 9320 010a                 				STS cnt_meses, R18
00037b 9130 0111                 				LDS R19, u_meses
00037d 953a                      				DEC R19
00037e 3f3f                      				CPI R19, 0xFF // Verificamos si hubo underflow
00037f f019                      				BREQ UNDERFLOW_D_MESES
000380 9330 0111                 				STS u_meses, R19
000382 c086                      				RJMP EXIT_ISR_PCINT0
                                 				
                                 				UNDERFLOW_D_MESES: // Pasamos de 10 a 09
000383 e039                      					LDI R19, 0x09
000384 9330 0111                 					STS u_meses, R19
000386 2744                      					CLR R20
000387 9340 0112                 					STS d_meses, R20
000389 c07f                      					RJMP EXIT_ISR_PCINT0
                                 
                                 				UNDERFLOW_MESES: // Cargamos diciembre
00038a e02c                      					LDI R18, 12
00038b 9320 010a                 					STS cnt_meses, R18 // Contador a 12
00038d e032                      					LDI R19, 0x02
00038e 9330 0111                 					STS u_meses, R19 // Unidades a 2
000390 e041                      					LDI R20, 0x01
000391 9340 0112                 					STS d_meses, R20 // Decenas a 1
000393 c075                      					RJMP EXIT_ISR_PCINT0
                                 
                                 			DEC_CONFIG_D_MESES:
000394 9120 0112                 				LDS R18, d_meses // cnt_meses = d_meses*10 + u_meses
000396 e05a                      				LDI R21, 0x0A
000397 9f25                      				MUL R18, R21
000398 9130 0111                 				LDS R19, u_meses
00039a 0e03                      				ADD R0, R19
00039b 2d20                      				MOV R18, R0
00039c 9320 010a                 				STS cnt_meses, R18
                                 
00039e 302b                      				CPI R18, 0x0B
00039f f350                      				BRLO UNDERFLOW_MESES // Si el valor del contador era igual o menor a 10 y restamos 10, cargamos diciembre
0003a0 502a                      				SUBI R18, 0x0A
0003a1 9320 010a                 				STS cnt_meses, R18
0003a3 9130 0112                 				LDS R19, d_meses
0003a5 953a                      				DEC R19
0003a6 9330 0112                 				STS d_meses, R19
0003a8 c060                      				RJMP EXIT_ISR_PCINT0
                                 
                                 	BOTON_3: // Botón de cambio de modo
0003a9 9110 011e                 		LDS R17, config
0003ab 3f1f                      		CPI R17, 0xFF
0003ac f091                      		BREQ B3_CONFIG // Si estamos en config = 0xFF, se hace esta secuencia: hora -> fecha -> alarma
                                 		
0003ad 9130 011f                 		LDS R19, modo
0003af 3030                      		CPI R19, 0x00 // Estamos en hora
0003b0 f051                      		BREQ BOTON_3B
0003b1 3f3f                      		CPI R19, 0xFF // Estamos en fecha
0003b2 f021                      		BREQ BOTON_3A
                                 
0003b3 e030                      		LDI R19, 0x00 // Si estamos en alarma sonando, pasamos a hora y la desactivamos 
0003b4 9330 011f                 		STS modo, R19
0003b6 c052                      		RJMP EXIT_ISR_PCINT0
                                 
                                 		BOTON_3A: // Pasar a hora (0)
0003b7 e030                      			LDI R19, 0x00
0003b8 9330 011f                 			STS modo, R19
0003ba c04e                      			RJMP EXIT_ISR_PCINT0
                                 
                                 		BOTON_3B: // Pasar a fecha
0003bb ef3f                      			LDI R19, 0xFF
0003bc 9330 011f                 			STS modo, R19
0003be c04a                      			RJMP EXIT_ISR_PCINT0
                                 
                                 		B3_CONFIG:
0003bf 9130 011f                 			LDS R19, modo
0003c1 3f3f                      			CPI R19, 0xFF // Estamos en fecha
0003c2 f0d1                      			BREQ BOTON_3C 
                                 
0003c3 3030                      			CPI R19, 0x00 // Estamos en hora
0003c4 f3b1                      			BREQ BOTON_3B
                                 
0003c5 e030                      			LDI R19, 0x00 // Pasamos a hora si estábamos en alarma
0003c6 9330 011f                 			STS modo, R19
                                 
                                 			// Si estábamos en alarma, guardamos los valores previos de hora
0003c8 9110 0118                 			LDS R17, backup_u_minutos
0003ca 9310 010b                 			STS u_minutos, R17
0003cc 9110 0119                 			LDS R17, backup_d_minutos
0003ce 9310 010c                 			STS d_minutos, R17
                                 
0003d0 9110 011a                 			LDS R17, backup_u_horas
0003d2 9310 010d                 			STS u_horas, R17
0003d4 9110 011b                 			LDS R17, backup_d_horas
0003d6 9310 010e                 			STS d_horas, R17
0003d8 9110 011c                 			LDS R17, backup_horas
0003da 9310 0108                 			STS cnt_horas, R17
0003dc c02c                      			RJMP EXIT_ISR_PCINT0
                                 
                                 		BOTON_3C: // Pasar a configurar alarma
0003dd e535                      			LDI R19, 0x55
0003de 9330 011f                 			STS modo, R19
                                 			
0003e0 9110 010b                 			LDS R17, u_minutos // Copia de seguridad de minutos
0003e2 9310 0118                 			STS backup_u_minutos, R17
                                 
0003e4 9110 010c                 			LDS R17, d_minutos // Copia de seguridad de minutos
0003e6 9310 0119                 			STS backup_d_minutos, R17
                                 
0003e8 9110 010d                 			LDS R17, u_horas
0003ea 9310 011a                 			STS backup_u_horas, R17
0003ec 9110 010e                 			LDS R17, d_horas
0003ee 9310 011b                 			STS backup_d_horas, R17
0003f0 9110 0108                 			LDS R17, cnt_horas // Copia de seguridad de horas
0003f2 9310 011c                 			STS backup_horas, R17
                                 
0003f4 c014                      			RJMP EXIT_ISR_PCINT0
                                 				
                                 	BOTON_4: // Botón para cambiar de display que se está configurando / apagar alarma
0003f5 9150 011e                 		LDS R21, config // revisamos si estamos en CONFIG desactivada
0003f7 3050                      		CPI R21, 0x00
0003f8 f059                      		BREQ B4_ALARMA // Si es así, nos vamos
                                 
0003f9 9160 0102                 		LDS R22, disp_config // Qué display estamos configurando?
0003fb 9563                      		INC R22 // Pasamos al siguiente display
0003fc 9360 0102                 		STS disp_config, R22 // Guardamos el nuevo valor
                                 	
0003fe 3064                      		CPI R22, 0x04 
0003ff f449                      		BRNE EXIT_ISR_PCINT0
000400 2766                      		CLR R22
000401 9360 0102                 		STS disp_config, R22 // Si pasamos de 3, regresamos a 0
000403 c005                      		RJMP EXIT_ISR_PCINT0
                                 
                                 		B4_ALARMA:
000404 e000                      			LDI R16, 0x00
000405 9300 011d                 			STS flag_alarma, R16
000407 985f                      			CBI PORTD, PORTD7
000408 c000                      			RJMP EXIT_ISR_PCINT0
                                 
                                 	EXIT_ISR_PCINT0:
000409 9310 0100                 		STS botones, R17 // Guardamos la lectura realizada como nueva lectura de botones
00040b 916f                      		POP R22
00040c 915f                      		POP R21
00040d 914f                      		POP R20
00040e 913f                      		POP R19
00040f 912f                      		POP R18
000410 911f                      		POP R17
000411 910f                      		POP R16
000412 bf0f                      		OUT SREG, R16
000413 910f                      		POP R16
000414 9518                      		RETI
                                 
                                 	// -------------------------------------------------------------------------------------------------------------------------------------------
                                 	// Interrupción de timer2
                                 	ISR_timer2:
000415 930f                      		PUSH R16
000416 b70f                      		IN   R16, SREG
000417 930f                      		PUSH R16
000418 931f                      		PUSH R17
000419 932f                      		PUSH R18
00041a 933f                      		PUSH R19
                                 
00041b ef0e                      		LDI R16, 254 // Empezamos a contar en 254
00041c 9300 00b2                 		STS TCNT2, R16
                                 
00041e b118                      		IN R17, PORTC
00041f 7013                      		ANDI R17, 0b0000_0011 // No modificamos el valor de las LEDs
000420 b918                      		OUT PORTC, R17 // Displays apagados por un instante
                                 
000421 9100 011d                 		LDS R16, flag_alarma // Verificamos si hay que encender la alarma
000423 3f0f                      		CPI R16, 0xFF
000424 f421                      		BRNE CONTINUAR_MUX // Si hay que encenderla, seguimos
                                 
000425 b11b                      		IN   R17, PORTD
000426 e800                      		LDI  R16, (1<<PD7)
000427 2710                      		EOR  R17, R16 // XOR para hacer toggle del valor del PD7
000428 b91b                      		OUT  PORTD, R17
                                 
                                 		CONTINUAR_MUX:
000429 9120 0101                 		LDS R18, disp_activo
00042b 3020                      		CPI R18, 0x00
00042c f031                      		BREQ show_dispd2
00042d 3021                      		CPI R18, 0x01
00042e f069                      		BREQ show_dispd1
00042f 3022                      		CPI R18, 0x02
000430 f0a1                      		BREQ show_dispi2
000431 3023                      		CPI R18, 0x03
000432 f0d9                      		BREQ show_dispi1
                                 
                                 	show_dispd2:
000433 9523                      		INC R18 // Cambiar de display activo en el próximo ciclo
000434 9110 0106                 		LDS R17, disp_d2 // Guardar el HEX del número que se va a mostrar (PD6-0)
000436 b13b                      		IN R19, PORTD // Guardamos el valor actual del PORTD
000437 7830                      		ANDI R19, 0b1000_0000 // Aislamos el valor del PD7 (buzzer)
000438 2b13                      		OR R17, R19 // OR de ambos registros para no modificar el estado del buzzer
000439 b91b                      		OUT PORTD, R17 // Mostrar el valor del número
00043a 9a44                      		SBI PORTC, 4 // Habilitar el display en cuestión
00043b c01b                      		RJMP RETURN_ISR_timer2
                                 	
                                 	show_dispd1:
00043c 9523                      		INC R18
00043d 9110 0105                 		LDS R17, disp_d1
00043f b13b                      		IN R19, PORTD
000440 7830                      		ANDI R19, 0b1000_0000
000441 2b13                      		OR R17, R19
000442 b91b                      		OUT PORTD, R17
000443 9a45                      		SBI PORTC, 5
000444 c012                      		RJMP RETURN_ISR_timer2
                                 	
                                 	show_dispi2:
000445 9523                      		INC R18
000446 9110 0104                 		LDS R17, disp_i2
000448 b13b                      		IN R19, PORTD
000449 7830                      		ANDI R19, 0b1000_0000
00044a 2b13                      		OR R17, R19
00044b b91b                      		OUT PORTD, R17
00044c 9a43                      		SBI PORTC, 3
00044d c009                      		RJMP RETURN_ISR_timer2
                                 	
                                 	show_dispi1:
00044e 2722                      		CLR R18
00044f 9110 0103                 		LDS R17, disp_i1
000451 b13b                      		IN R19, PORTD
000452 7830                      		ANDI R19, 0b1000_0000
000453 2b13                      		OR R17, R19
000454 b91b                      		OUT PORTD, R17
000455 9a42                      		SBI PORTC, 2
000456 c000                      		RJMP RETURN_ISR_timer2
                                 
                                 	RETURN_ISR_timer2:
000457 9320 0101                 		STS disp_activo, R18
000459 913f                      		POP R19
00045a 912f                      		POP R18
00045b 911f                      		POP R17
00045c 910f                      		POP R16
00045d bf0f                      		OUT SREG, R16
00045e 910f                      		POP R16
00045f 9518                      		RETI
                                 
                                 	// -------------------------------------------------------------------------------------------------------------------------------------------
                                 	ISR_timer1:
000460 930f                      		PUSH R16
000461 b70f                      		IN   R16, SREG
000462 930f                      		PUSH R16
000463 931f                      		PUSH R17
000464 932f                      		PUSH R18
                                 
000465 e10b                      		LDI R16, 0x1B
000466 9300 0085                 		STS TCNT1H, R16 // Valor inicial H para 60s
000468 e10e                      		LDI R16, 0x1E
000469 9300 0084                 		STS TCNT1L, R16 // Valor inicial L para 60s
                                 
00046b 9100 011e                 		LDS R16, config // Si estamos en modo configuración, no incrementamos el contador de minutos
00046d 3f0f                      		CPI R16, 0xFF
00046e f0e1                      		BREQ RETURN_ISR_timer1
                                 
00046f 9110 010b                 		LDS R17, u_minutos // Cargamos el valor de unidades de minuto
000471 9513                      		INC R17 // Incrementamos el valor de unidades de minuto
000472 9310 010b                 		STS u_minutos, R17 // Guardamos el nuevo valor
                                 
                                 		// Verificamos si se debe activar la alarma
000474 9110 010b                 		LDS R17, u_minutos
000476 9120 0113                 		LDS R18, al_u_minutos
000478 1712                      		CP R17, R18
000479 f489                      		BRNE RETURN_ISR_timer1
                                 
00047a 9110 010c                 		LDS R17, d_minutos
00047c 9120 0114                 		LDS R18, al_d_minutos
00047e 1712                      		CP R17, R18
00047f f459                      		BRNE RETURN_ISR_timer1
                                 
000480 9110 0108                 		LDS R17, cnt_horas
000482 9120 0117                 		LDS R18, al_horas
000484 1712                      		CP R17, R18
000485 f429                      		BRNE RETURN_ISR_timer1
                                 
000486 ef2f                      		LDI R18, 0xFF
000487 9320 011d                 		STS flag_alarma, R18 // Si llegamos a esta línea, se debe activar la alarma 
000489 9a5f                      		SBI PORTD, PORTD7
                                 
00048a c000                      		RJMP RETURN_ISR_timer1
                                 
                                 	RETURN_ISR_timer1:
00048b 912f                      		POP R18
00048c 911f                      		POP R17
00048d 910f                      		POP R16
00048e bf0f                      		OUT SREG, R16
00048f 910f                      		POP R16
000490 9518                      		RETI
                                 
                                 	// -------------------------------------------------------------------------------------------------------------------------------------------
                                 	// Interrupción por timer0
                                 	ISR_timer0:
000491 930f                      		PUSH R16
000492 b70f                      		IN   R16, SREG
000493 930f                      		PUSH R16
000494 931f                      		PUSH R17
000495 932f                      		PUSH R18
000496 933f                      		PUSH R19
000497 934f                      		PUSH R20
                                 		
000498 e00c                      		LDI R16, 12 // Empezamos a contar en 12
000499 bd06                      		OUT TCNT0, R16
                                 
00049a 9100 011e                 		LDS R16, config
00049c 3f0f                      		CPI R16, 0xFF
00049d f061                      		BREQ RETURN_ISR_timer0
                                 
00049e 9110 0107                 		LDS R17, cnt_LEDR
0004a0 9513                      		INC R17
0004a1 9310 0107                 		STS cnt_LEDR, R17
0004a3 3012                      		CPI R17, 2
0004a4 f429                      		BRNE RETURN_ISR_timer0
                                 		
0004a5 2711                      		CLR R17
0004a6 9310 0107                 		STS cnt_LEDR, R17
0004a8 9a1d                      		SBI PINB, PINB5
                                 
0004a9 c000                      		RJMP RETURN_ISR_timer0
                                 
                                 	RETURN_ISR_timer0:		
0004aa 914f                      		POP R20
0004ab 913f                      		POP R19
0004ac 912f                      		POP R18
0004ad 911f                      		POP R17
0004ae 910f                      		POP R16
0004af bf0f                      		OUT SREG, R16
0004b0 910f                      		POP R16
0004b1 9518                      		RETI 
                                 	
                                 // *********************************************************************************************************************************************//
